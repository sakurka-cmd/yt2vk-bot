# VK Community Bot
VK_TOKEN=your_vk_group_token
VK_GROUP_ID=12345678

# Database
DATABASE_URL=data/yt2vk_bot.db

# YouTube check interval (seconds, default 3600 = 1 hour)
CHECK_INTERVAL=3600

# Temp directory for downloads (cleaned after upload)
TMP_DIR=/tmp/yt2vk

# Max video file size in bytes (default 2GB). 0 = no limit
MAX_FILE_SIZE=2147483648

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
